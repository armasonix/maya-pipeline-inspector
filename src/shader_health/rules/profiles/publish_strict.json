{
  "id": "publish_strict",
  "display_name": "Publish Strict",
  "manifest_diff_policy": {
    "max_new_changes": 0,
    "max_fingerprint_changes": 0,
    "block_on_new_textures": true
  },
  "rule_overrides": {
    "vray.scene.plugin_missing.error": {
      "block_publish": true
    },
    "vray.material.displacement_review.warning": {
      "block_publish": true
    },
    "vray.material.texture_budget.warning": {
      "block_publish": true
    },
    "arnold.scene.plugin_missing.error": {
      "block_publish": true
    },
    "arnold.material.displacement_review.warning": {
      "block_publish": true
    },
    "arnold.material.texture_budget.warning": {
      "block_publish": true
    }
  }
}
